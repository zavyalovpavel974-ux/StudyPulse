# StudyPulse environment variables
#
# Copy this file to .env for your own notes, or set these variables in your
# shell / Windows user environment. Do not commit real secrets.

# MiMo / OpenAI-compatible API
MIMO_API_KEY=

# SMTP email notification
STUDYPULSE_SMTP_HOST=smtp.example.com
STUDYPULSE_SMTP_PORT=465
STUDYPULSE_SMTP_USER=your-email@example.com
STUDYPULSE_SMTP_PASSWORD=your-app-password
STUDYPULSE_SMTP_SSL=1
STUDYPULSE_NOTIFY_EMAIL_FROM=your-email@example.com
STUDYPULSE_NOTIFY_EMAIL_TO=recipient@example.com

# Optional: choose a non-default local config path
STUDYPULSE_CONFIG=
